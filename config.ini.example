# Runtime configuration for Splunk Utility Tool v4.
# Keep each section header on its own line and each setting as `key = value`.
# If config.ini is missing, the tool recreates it from this template.
# If formatting is repaired automatically, the previous file is saved as config.ini.bak.

[splunk]
# Primary endpoint (Splunk management port)
host = https://splunk-sh-vip:8089

# Backward-compatible list form (first entry is used for startup checks/connect)
servers = https://splunk-sh-vip:8089

# v4 is password-only (DPAPI secret file). Token/CLI auth is not supported.
auth_mode = password
# TLS certificate verification can be disabled for internal/self-signed cert deployments.
# HTTPS is still mandatory; http:// endpoints are rejected.
verify_ssl = false

# Legacy token settings are unsupported in v4:
# token_storage, token, token_ini, token_encrypted, splunk_cli_path

# Legacy plaintext password entry is ignored by v4 (do not use)
# password =

[Credentials]
username = splunk_service
secret_file = secret.dpapi
dpapi_scope = machine

[Security]
build_mode = production
policy_mode = enforced
allow_insecure_overrides = false

[Logging]
level = INFO
verbose = false
max_bytes = 10485760
backup_count = 10

[mergereport]
# Legacy file-based MergeReport monitoring (use [postdispatch] instead)
# If [postdispatch] merge_report_* keys are present, this section is ignored.
enabled = false
log_path =
timeout_seconds = 300

[dispatch]
# Active wait budget per slice before moving on.
# This does not kill the Splunk job; it only limits how long the tool waits actively.
per_slice_wait_seconds = 30
continue_on_timeout = true
timeout_result = pending

[email]
# Acknowledgement email is enabled by default.
# Legacy alias `ack_on_unknown` is still accepted, but `ack_on_pending` is preferred.
ack_enabled = 1
ack_on_pending = 0
ack_recipients =
ack_use_savedsearch_recipients = 0
ack_attach_manifest = 0

# SMTP settings for ACK summary email
smtp_host = 127.0.0.1
smtp_port = 25
smtp_tls = 0
smtp_user =
smtp_pass =
from_addr = Splunk Notification <splunk-donotreply@dsta.gov.sg>

[postdispatch]
# Post-dispatch status verification via Splunk REST searches (primary method)
# Verifies actual email/alert action completion by querying _internal logs

# MergeReport verification settings
merge_report_enabled = true
# Optional file-based MergeReport log path (absolute). Leave blank to disable file tailing.
merge_report_log_path =
merge_report_index = _internal
merge_report_source_contains = mergeReport_alert.log
merge_report_sourcetype =
merge_report_timeout_seconds = 300

# Native Splunk email action verification settings
native_email_enabled = true
native_email_index = _internal
native_email_source_contains = python.log
native_email_sourcetype =
native_email_timeout_seconds = 300

# Broker timeout for slower local broker requests
broker_request_timeout_seconds = 300

# Run one bounded reconciliation pass after all slices are attempted
reconcile_pending = true
reconcile_wait_seconds = 60

# Native email strictness: if false (default), success = invoked + no error
# if true, requires explicit success marker in logs (else remains PENDING)
native_email_strict_success = false

# Polling parameters
poll_seconds = 5
lookback_seconds = 900
